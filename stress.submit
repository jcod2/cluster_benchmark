executable = stress_test.py

output     = stress_job_$(Cluster)_$(Process)_$(Machine).out
error      = stress_job_$(Cluster)_$(Process)_$(Machine).err
log        = stress.log

request_cpus   = 1
request_memory = 1GB
request_disk   = 2GB

+MaxRuntime = 43200         # 12 hours (safety)
kill_sig = SIGTERM

queue 36
